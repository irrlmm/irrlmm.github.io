---
import type { CollectionEntry } from "astro:content";
import SectionHeader from "./SectionHeader.astro";
import SectionWorkItem from "./SectionWorkItem.astro";

type Props = {
  title: string;
  link?: string;
  items: CollectionEntry<"work">[];
};

const { title, link, items } = Astro.props;
---

<div class="ui">
  <SectionHeader title={title} link={link} />

  <ul class="ui-list">
    {
      items.map(({ data: caseStudy, id }) => (
        <SectionWorkItem
          id={id}
          title={caseStudy.title}
          tag={caseStudy.tag}
          org={caseStudy.org}
        />
      ))
    }
  </ul>
</div>

<style>
  div {
    width: 100%;
    max-width: 40rem;
  }

  ul {
    display: grid;
    max-width: initial;
    grid-template-columns: repeat(2, 1fr);
    flex-direction: column;
    gap: 1px;
    padding: 1px;
    background-color: var(--outline);
    border-radius: var(--br-square);
  }

  @media (max-width: 40rem) {
    ul {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>
