---
import ThemeSwitch from "./ThemeSwitch.astro";
import PaletteSwitch from "../components/PaletteSwitch";

type Props = {
  text?: string;
  showPaletteSwitch?: boolean;
};

const { showPaletteSwitch = true, text = "Igor Lemeshkin" } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const root = segments[0];

const routeLinks: Record<string, string> = {
  work: "Case study",
  artifact: "Artifact",
  cv: "CV",
};

const resolvedBreadcrumb =
  segments.length >= 1 && root ? routeLinks[root] : undefined;

const nameParts = text.trim().split(/\s+/).filter(Boolean);

const shorterName =
  nameParts.length >= 2 ? `${nameParts[0]}'s` : (nameParts[0] ?? text);
---

<header class="overline text-l max-width-m">
  <div class="row gap-4 align-center">
    <a href="/">{segments.length > 1 ? shorterName : text}</a>
    {
      resolvedBreadcrumb && (
        <span class="color-primary lh-capped">{resolvedBreadcrumb}</span>
      )
    }
  </div>

  <div class="controls">
    {showPaletteSwitch && <PaletteSwitch client:only="react" />}

    <ThemeSwitch />
  </div>
</header>

<style>
  header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .controls {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    /* animation: appear 0.4s var(--bezier) both; */
    /* animation-delay: 0.4s; */
  }

  a {
    display: inline-flex;
    color: var(--on-surface);
    text-decoration: none;
    height: 2.5rem;
    align-items: center;
  }

  .dash {
    opacity: 0.2;
  }
</style>
