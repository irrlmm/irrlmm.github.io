---
import { IRRLMM } from "../consts/meta";
import ThemeSwitch from "./ThemeSwitch.astro";

type Props = {
  breadcrumb?: UI.Link;
};

const { breadcrumb } = Astro.props;
const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const root = segments[0];

const routeLinks: Record<string, UI.Link> = {
  work: { label: "Work", href: "/work" },
  blog: { label: "Blog", href: "/blog" },
  about: { label: "About", href: "/about" },
};

const resolvedBreadcrumb =
  breadcrumb ?? (segments.length > 1 && root ? routeLinks[root] : undefined);
---

<header class="overline-l">
  <div>
    <a href="/">
      <span class="lh-capped">{IRRLMM.name}</span>
    </a>
    {
      resolvedBreadcrumb && (
        <>
          <span class="dash lh-capped">/</span>

          <a href={resolvedBreadcrumb.href}>
            <span class="lh-capped">{resolvedBreadcrumb.label}</span>
          </a>
        </>
      )
    }
  </div>

  <ThemeSwitch />
</header>

<style>
  header {
    width: 100%;
    max-width: 40rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  header > div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  a {
    display: inline-flex;
    color: var(--on-surface);
    text-decoration: none;
    height: 2.5rem;
    align-items: center;
  }

  .dash {
    opacity: 0.2;
  }
</style>
