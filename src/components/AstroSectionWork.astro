---
import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import getAverageImageColorServer from "../helpers/getAverageImageColorServer";
import getOptimizedImage from "../helpers/getOptimizedImage";
import getSvgMaskImageServer from "../helpers/getSvgMaskImageServer";
import SectionWork from "./SectionWork";
import type { ArtifactStack, WorkWithOrg } from "./cards/types";
import type { SectionWorkItem } from "./SectionWork/types";

type Props = {
  items?: Array<CollectionEntry<"artifacts"> | CollectionEntry<"work">>;
  includeDrafts?: boolean;
};

const { items, includeDrafts = false }: Props = Astro.props;

type SourceItem = CollectionEntry<"artifacts"> | CollectionEntry<"work">;

const loadSourceItems = async (): Promise<SourceItem[]> => {
  if (items) {
    return items;
  }

  const fetchedArtifacts = await getCollection(
    "artifacts",
    ({ data }) => includeDrafts || !data.draft,
  );
  const fetchedWork = await getCollection(
    "work",
    ({ data }) => includeDrafts || !data.draft,
  );

  return [...fetchedArtifacts, ...fetchedWork];
};

const prepareArtifactItem = async (
  item: CollectionEntry<"artifacts">,
): Promise<SectionWorkItem> => {
  if (item.data.type !== "stack") {
    return {
      kind: "artifact-note",
      item,
    };
  }

  try {
    const layers = await Promise.all(
      item.data.images.map(async (image) => {
        const [optimized, imageColors] = await Promise.all([
          getOptimizedImage(image, 512),
          getAverageImageColorServer(image),
        ]);

        return {
          src: optimized.src,
          imageColors,
        };
      }),
    );

    const stackItem: ArtifactStack = {
      ...item,
      data: {
        ...item.data,
        images: layers,
      },
    };

    return {
      kind: "artifact-stack",
      item: stackItem,
    };
  } catch (error) {
    throw new Error(
      `Failed to optimize images for artifact stack: ${item.id}`,
      {
        cause: error,
      },
    );
  }
};

const prepareWorkItem = async (
  item: CollectionEntry<"work">,
): Promise<SectionWorkItem> => {
  const orgEntry = await getEntry(item.data.org);
  if (!orgEntry) {
    throw new Error(`Missing org entry for work item: ${item.id}`);
  }

  try {
    const [optimizedCoverImage, optimizedOrgImage] = await Promise.all([
      getOptimizedImage(item.data.coverImage, 1024),
      getSvgMaskImageServer(orgEntry.data.img, 256),
    ]);

    const colors = await getAverageImageColorServer(item.data.coverImage);

    const optimizedWorkItem: WorkWithOrg = {
      ...item,
      data: {
        ...item.data,
        coverImage: optimizedCoverImage.src,
        colors,
        orgImage: optimizedOrgImage.src,
        orgImageAspect: optimizedOrgImage.aspectRatio,
        orgName: orgEntry.data.name,
      },
    };

    return {
      kind: "work-default",
      item: optimizedWorkItem,
    };
  } catch (error) {
    throw new Error(`Failed to optimize images for work item: ${item.id}`, {
      cause: error,
    });
  }
};

const prepareItem = async (item: SourceItem): Promise<SectionWorkItem> => {
  if (item.collection === "artifacts") {
    return prepareArtifactItem(item);
  }

  return prepareWorkItem(item);
};

const sourceItems = await loadSourceItems();
const processedItems = await Promise.all(sourceItems.map(prepareItem));

processedItems.sort(
  (a, b) => b.item.data.date.getTime() - a.item.data.date.getTime(),
);
---

<SectionWork items={processedItems} client:load />
