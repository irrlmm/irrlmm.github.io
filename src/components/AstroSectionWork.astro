---
import { getEntry, type CollectionEntry } from "astro:content";
import getOptimizedImage from "../helpers/getOptimizedImage";
import getAverageImageColorServer from "../helpers/getAverageImageColorServer";

import SectionWork from "./SectionWork";
import type {
  CollectionEntryType,
  WorkCollectionWithOrgInfo,
} from "./SectionWork/types";

type Props = {
  items: Array<CollectionEntry<"artifacts"> | CollectionEntry<"work">>;
};

const { items }: Props = Astro.props;

const processedItems: CollectionEntryType[] = await Promise.all(
  items.map(async (item) => {
    if (item.collection === "artifacts") {
      if (item.data.type !== "stack" || !item.data.images?.length) {
        return item;
      }

      try {
        const [optimizedImages, imageColors] = await Promise.all([
          Promise.all(
            item.data.images.map(async (image) => {
              const optimized = await getOptimizedImage(image, 512);
              return optimized.src;
            }),
          ),
          Promise.all(
            item.data.images.map(async (image) => getAverageImageColorServer(image)),
          ),
        ]);

        return {
          ...item,
          data: {
            ...item.data,
            images: optimizedImages,
            imageColors,
          },
        };
      } catch (error) {
        throw new Error(
          `Failed to optimize images for artifact stack: ${item.id}`,
          {
            cause: error,
          },
        );
      }
    }

    const orgEntry = await getEntry(item.data.org);
    if (!orgEntry) {
      throw new Error(`Missing org entry for work item: ${item.id}`);
    }

    try {
      const [optimizedCoverImage, optimizedOrgImage] = await Promise.all([
        getOptimizedImage(item.data.coverImage, 512),
        getOptimizedImage(orgEntry.data.img, 256),
      ]);

      const colors = await getAverageImageColorServer(item.data.coverImage);

      const optimizedWorkItem: WorkCollectionWithOrgInfo = {
        ...item,
        data: {
          ...item.data,
          coverImage: optimizedCoverImage.src,
          colors,
          orgImage: optimizedOrgImage.src,
          orgName: orgEntry.data.name,
        },
      };

      return optimizedWorkItem;
    } catch (error) {
      throw new Error(`Failed to optimize images for work item: ${item.id}`, {
        cause: error,
      });
    }
  }),
);

processedItems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<SectionWork items={processedItems} client:load />
