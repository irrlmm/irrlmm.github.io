---
import { IRRLMM } from "../consts/meta";
import { SVG_ARROW } from "../consts/svg";
import type { Link } from "../types/content";
import Svg from "./Svg.astro";
import ThemeSwitch from "./ThemeSwitch.astro";

type Props = {
};

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const root = segments[0];
const backHref = segments.length > 1 && root ? `/${root}` : "/";

const routeLinks: Record<string, Link> = {
  work: { label: "Work", href: "/work" },
  posts: { label: "Posts", href: "/posts" },
  notes: { label: "Notes", href: "/notes" },
  about: { label: "About", href: "/about" },
};

const resolvedBreadcrumb =
  segments.length > 1 && root ? routeLinks[root] : undefined;
---

<header>
  <div class="left">
    {
      pathname !== "/" && (
        <a class="back-button" href={backHref} aria-label="Go back">
          <Svg d={SVG_ARROW} />
        </a>
      )
    }

    <a class="link-index" href="/">
      <span class="lh-capped">{IRRLMM.name}</span>
    </a>
    {
      resolvedBreadcrumb && (
        <>
          <span class="dash lh-capped">/</span>

          <a class="link-breadcrumb" href={resolvedBreadcrumb.href}>
            <span class="lh-capped">{resolvedBreadcrumb.label}</span>
          </a>
        </>
      )
    }
  </div>

  <ThemeSwitch />
</header>

<style>
  header {
    font-size: 1.125rem;
    width: 100%;
    max-width: 40rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  svg {
    fill: var(--on-surface);
    height: 1.5rem;
  }

  a {
    display: inline-flex;
    color: var(--on-surface);
    text-decoration: none;
    height: 2.5rem;
    align-items: center;
  }

  img {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 0.0625rem solid var(--on-surface);
  }

  .row-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .row-left > span {
    opacity: 0.2;
  }

  .link-index {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    gap: 1rem;
  }

  .link-breadcrumb {
    gap: 0.5rem;
  }

  .back-button {
    justify-content: center;
    width: 2.5rem;
  }

  .dash {
    opacity: 0.2;
  }
</style>
