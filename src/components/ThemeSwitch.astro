---
import { SVG_SUN, SVG_MOON, SVG_SUN_AUTO, SVG_MOON_AUTO } from "../consts/svg";
---

<button id="theme-toggle">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    width="1.5rem"
    height="1.5rem"
    stroke-width="1.5"
    stroke="var(--on-surface)"
  >
    <path d={SVG_SUN} data-theme="light" vector-effect="non-scaling-stroke"
    ></path>

    <path d={SVG_MOON} data-theme="dark" vector-effect="non-scaling-stroke"
    ></path>

    <path
      d={SVG_SUN_AUTO}
      data-theme="auto light"
      vector-effect="non-scaling-stroke"></path>

    <path
      d={SVG_MOON_AUTO}
      data-theme="auto dark"
      vector-effect="non-scaling-stroke"></path>
  </svg>
</button>

<style>
  button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5em;
    padding: 0;
    border: none;
    background-color: transparent;
    transition: opacity 0.2s var(--bezier);
    cursor: pointer;
  }
  button:hover {
    opacity: 0.5;
  }

  path {
    display: none;
  }

  html[data-theme="dark"] path[data-theme="dark"] {
    display: initial;
  }
  html[data-theme="light"] path[data-theme="light"] {
    display: initial;
  }
  @media (prefers-color-scheme: light) {
    html[data-theme="auto"] path[data-theme="auto light"] {
      display: initial;
    }
  }
  @media (prefers-color-scheme: dark) {
    html[data-theme="auto"] path[data-theme="auto dark"] {
      display: initial;
    }
  }
</style>

<script is:inline>
  (function () {
    // Apply the theme by setting a data attribute on <html>
    function applyTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);
      // console.log(`Theme set to: ${theme}`);
    }

    // Update theme based on stored preference and system settings (if in auto)
    function updateTheme() {
      const theme = localStorage.getItem("theme") || "auto";
      applyTheme(theme);
    }

    // Initial theme setup
    updateTheme();

    // Listen for system theme changes – only respond when in 'auto' mode
    const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
    mediaQuery.addEventListener("change", function () {
      if ((localStorage.getItem("theme") || "auto") === "auto") {
        updateTheme();
      }
    });

    // Theme toggle listener cycles through: auto -> dark -> light -> auto
    const toggleButton = document.getElementById("theme-toggle");
    if (toggleButton) {
      toggleButton.addEventListener("click", function () {
        const current = localStorage.getItem("theme") || "auto";
        let next;
        switch (current) {
          case "auto":
            if (mediaQuery.matches) {
              next = "light";
            } else {
              next = "dark";
            }
            break;
          case "dark":
          case "light":
          default:
            next = "auto";
            break;
        }
        localStorage.setItem("theme", next);
        updateTheme();
      });
    }
  })();
</script>
