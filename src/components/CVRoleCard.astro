---
import moment from "moment";

type Props = {
  dateStart: Date;
  dateEnd: Date;
  role: string;
  type?: string;
  experience?: string[];
};

const { dateStart, dateEnd, role, type, experience } = Astro.props;
---

<div class="role-card">
  <div class="row">
    <span class="eyebrow lh-capped">
      {moment(dateStart).year()} - {moment(dateEnd).year()}
    </span>

    {type && <span class="eyebrow lh-capped">{type}</span>}
  </div>

  <div class="col">
    <h4>{role}</h4>
  </div>

  {
    experience && experience.length > 0 && (
      <>
        <div class="separator" />

        <ul>
          {experience.map((e) => (
            <li>
              <span>•</span>
              <p>{e}</p>
            </li>
          ))}
        </ul>
      </>
    )
  }
</div>

<style>
  .role-card {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background-color: var(--inverse-surface);
    color: var(--inverse-on-surface);
    box-shadow: inset 0 0 0 var(--line) var(--inverse-surface);
    border-radius: 2rem;
    padding: 2rem;
  }
</style>
