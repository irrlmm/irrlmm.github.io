---
import { getEntry, render } from "astro:content";

import Layout from "../layouts/Layout.astro";

const page = await getEntry("pages", "404");

if (!page) {
  throw Error("index page not found!");
}

const { Content } = await render(page);
---

<Layout head={{ title: page.data.title, description: page.data.description }}>
  <Content />
</Layout>

<style is:global>
  :root {
    --background: #030900;
    --surface: #010501;
    --on-surface: #96fc00;
    --on-surface-overlay: #96fc0008;
    --outline: var(--on-surface);
    --pixel-grid-line: rgba(57, 255, 20, 1);
    text-align: justify;
    letter-spacing: 0.05em;
  }

  p {
    font-size: 1.5rem;
    text-transform: uppercase;
    max-width: 40rem;
    line-height: 1.5em;
  }
</style>
