---
import { SCHEMA_PERSON_FULL } from "../consts/schemas";

import { getEntry, render } from "astro:content";

import Layout from "../layouts/Layout.astro";
import moment from "moment";

const page = await getEntry("pages", "index");

if (!page) {
  throw Error("index page not found!");
}

const { Content } = await render(page);
---

<Layout
  head={{ title: "Title", description: "Description" }}
  schema={SCHEMA_PERSON_FULL}
  footerItems={[
    { label: "prd", value: "irrlmm", capsule: "v3" },
    {
      label: "upd",
      value: moment(page.data.updated).format("DD MMM YYYY") || "null",
    },
    { label: "loc", value: "Berlin", capsule: "DE" },
  ]}
>
  <article class="prose">
    <Content />
  </article>
</Layout>
