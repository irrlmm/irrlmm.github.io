---
import {
  type CollectionEntry,
  getCollection,
  getEntry,
  render,
} from "astro:content";

import moment from "moment";

import Layout from "../../layouts/Layout.astro";

import OrgPill from "../../components/OrgPill.astro";
import Classified from "../../components/Classified.astro";
import Quote from "../../components/Quote.astro";
import Hero from "../../components/Hero";
import getSvgMaskImageServer from "../../helpers/getSvgMaskImageServer";

export async function getStaticPaths() {
  const posts = await getCollection("work", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"work">;

const post = Astro.props;
const org = await getEntry(post.data.org);
const optimizedOrgImage = await getSvgMaskImageServer(org.data.img, 256);

const { Content, remarkPluginFrontmatter } = await render(post);
---

<Layout
  theme={post.data.theme}
  head={{ title: "", description: "" }}
  footerItems={[
    { label: "prj", value: post.id },
    { label: "clt", value: org.data.name, capsule: org.data.countryCode },
    {
      label: "dte",
      value: moment(post.data.date).format("MMM 'YY"),
    },
  ]}
>
  <!-- <AstroWorkImageStack srcs={stackImages} /> -->

  <article class="prose">
    <Hero
      title={post.data.title}
      readingTime={remarkPluginFrontmatter.readingTime}
      values={[
        // { label: "Year", value: moment(post.data.date).format("YYYY") },
        {
          label: "Client",
          type: "org",
          value: {
            name: org.data.name,
            orgImage: optimizedOrgImage.src,
            orgImageAspect: optimizedOrgImage.aspectRatio,
          },
        },
        // { label: "Tag", value: post.data.tag },
        { label: "Role", value: post.data.role },
        { label: "Engagement", value: post.data.engagement },
        { label: "Duration", value: post.data.duration },
        { label: "Team", value: post.data.team },
        // { label: "Impact", value: post.data.impact },
      ]}
      client:load
    />

    <Content
      components={{ Org: OrgPill, del: Classified, blockquote: Quote }}
    />
  </article>
</Layout>

<style>
  /* .kicker {
    margin-top: 1rem;
  } */
</style>
