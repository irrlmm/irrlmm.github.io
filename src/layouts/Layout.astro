---
import Head from "../components/Head.astro";
import type { WithContext, Person, Article, CreativeWork } from "schema-dts";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getRootThemeStyle, type Theme } from "../helpers/themeTokens";

interface Props {
  headerText?: string;
  head: {
    title: string;
    description: string;
  };
  footerItems?: { label?: string; value: string; capsule?: string }[];
  theme?: Theme;
  schema?: WithContext<Person | Article | CreativeWork>;
}

const { headerText, schema, head, footerItems, theme } = Astro.props;

const rootStyle = theme ? getRootThemeStyle(theme) : undefined;
---

<html lang="en" style={rootStyle}>
  <head>
    <Head title={head.title} description={head.description} />
    {
      schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }
  </head>

  <body transition:animate="none">
    <div id="top-gradient"></div>

    <Header text={headerText} showPaletteSwitch={!theme} />

    <main>
      <slot />
    </main>

    <hr />

    <Footer items={footerItems} />
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 8vw, 8rem);
  }

  main {
    width: 100%;
    animation: appear 0.4s var(--bezier) both;
    animation-delay: 0.4s;
  }

  #top-gradient {
    z-index: 100;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 8rem;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--background) 100%, transparent) 0%,
      color-mix(in srgb, var(--background) 92%, transparent) 8%,
      color-mix(in srgb, var(--background) 82%, transparent) 16%,
      color-mix(in srgb, var(--background) 70%, transparent) 25%,
      color-mix(in srgb, var(--background) 58%, transparent) 35%,
      color-mix(in srgb, var(--background) 46%, transparent) 46%,
      color-mix(in srgb, var(--background) 34%, transparent) 58%,
      color-mix(in srgb, var(--background) 23%, transparent) 70%,
      color-mix(in srgb, var(--background) 14%, transparent) 82%,
      color-mix(in srgb, var(--background) 7%, transparent) 92%,
      transparent 100%
    );
  }
</style>
