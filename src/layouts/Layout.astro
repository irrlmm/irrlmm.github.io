---
import Head from "../components/Head.astro";
import type { WithContext, Person, Article, CreativeWork } from "schema-dts";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  head: {
    title: string;
    description: string;
  };
  header?: {
    breadcrumb?: UI.Link;
  };
  footerItems?: { label?: string; value: string; capsule?: string }[];
  schema?: WithContext<Person | Article | CreativeWork>;
}

const { schema, head, header, footerItems } = Astro.props;
---

<html lang="en">
  <head>
    <Head title={head.title} description={head.description} />
    {
      schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }
  </head>

  <body>
    <Header breadcrumb={header?.breadcrumb} />

    <main>
      <slot />
    </main>

    <hr />

    <Footer items={footerItems} />

    <!-- <div id="overlay"></div> -->
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    padding: 8rem;
    animation: appear 0.3s var(--bezier) both;
    animation-delay: 0.2s;
  }

  main {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  #overlay {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    pointer-events: none;
    background:
      linear-gradient(
        to right,
        rgba(0, 0, 0, 0),
        rgba(0, 0, 0, 0) 50%,
        var(--pixel-grid-line) 50%
      ),
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0),
        rgba(0, 0, 0, 0) 50%,
        var(--pixel-grid-line) 50%
      );
    background-size: var(--line) var(--line);
    animation: decor-appear 0.6s var(--bezier) both;
  }

  @media (max-width: 64rem) {
    body {
      padding: 6rem 2rem;
    }
  }

  @media (max-width: 40rem) {
    body {
      padding: 4rem 1rem;
    }
  }
</style>
